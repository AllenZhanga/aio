APP_MODE=private
DEPLOYMENT_PROFILE=embedded
APP_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:3000

SERVER_PORT=8080

DB_MODE=embedded
DB_HOST=postgres
DB_PORT=5432
DB_NAME=aio
DB_USER=aio
DB_PASSWORD=replace-with-random-password

REDIS_URL=redis://redis:6379/0

STORAGE_TYPE=s3
STORAGE_MODE=embedded
S3_ENDPOINT=http://minio:9000
S3_BUCKET=aio
S3_ACCESS_KEY=replace-with-random-access-key
S3_SECRET_KEY=replace-with-random-secret-key
S3_FORCE_PATH_STYLE=true

VECTOR_STORE=qdrant
VECTOR_MODE=embedded
QDRANT_URL=http://qdrant:6333

DEFAULT_TENANT_ID=default
ENABLE_MULTI_TENANT=false
ENABLE_STDIO_MCP=false
ENABLE_CODE_NODE=false
